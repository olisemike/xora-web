# ===============================================
# Xora Social - Environment Variables Template
# ===============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ===============================================

# API Configuration
# ------------------
# Your backend API base URL
VITE_API_URL=http://localhost:5000/api

# WebSocket Configuration
# ------------------------
# WebSocket server URL for real-time features
VITE_WS_URL=ws://localhost:8080

# Push Notifications (PWA)
# -------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Public key for push notifications (client-side)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE

# Feature Flags
# --------------
# Enable/disable features
VITE_ENABLE_PWA=true

# File Upload
# -----------
# Maximum file size for uploads (in bytes)
VITE_MAX_FILE_SIZE=10485760

# Development
# -----------
# Enable debug mode
VITE_DEBUG_MODE=false

# API request timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# Social Media URLs
# -----------------
VITE_APP_URL=https://xorasocial.com
VITE_CDN_URL=https://cdn.xorasocial.com

# Cloudflare Media Configuration
# ------------------------------
# Get these from your Cloudflare dashboard > Images/Stream settings
VITE_CLOUDFLARE_IMAGES_HASH=your-cloudflare-images-hash
VITE_CLOUDFLARE_STREAM_SUBDOMAIN=customer-xxxxx.cloudflarestream.com
VITE_CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-images-hash

# reCAPTCHA v3 Site Key
# Register your domains in Google reCAPTCHA admin console and set the site key here
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
